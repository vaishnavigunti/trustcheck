{
  "framework": "nextjs",
  "build": {
    "env": {
      "NEXT_PUBLIC_API_URL": "https://trustcheck-api-production.up.railway.app",
      "NEXT_PUBLIC_APP_NAME": "TrustCheck"
    }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
